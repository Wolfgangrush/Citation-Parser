<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sccparser.service</string>
    <key>ProgramArguments</key>
    <array>
        <string>/path/to/sccparser/start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>/path/to/sccparser</string>
    <key>StandardOutPath</key>
    <string>/path/to/sccparser/logs/service.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/sccparser/logs/service-error.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>SCCPARSER_PORT</key>
        <string>5757</string>
        <key>OPEN_DASHBOARD</key>
        <string>false</string>
    </dict>
</dict>
</plist>
