# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Backend
BACKEND_URL=http://localhost:5757
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5757
DATABASE_PATH=./instance/citations.db
PDF_STORAGE_PATH=./pdfs_received
DELETE_PDF_AFTER_PROCESSING=true

# AI provider: ollama, gemini, local_http, codex_cli
AI_PROVIDER=ollama

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
AI_MAX_CHARS=350000

# Ollama, used when AI_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_NUM_CTX=32768
HIGH_COURT_ORDER_USE_AI=false

# Local HTTP parser, used when AI_PROVIDER=local_http.
# The endpoint should accept {"filename": "...", "text": "...", "schema": {...}}
# and return the citation JSON.
LOCAL_AI_ENDPOINT=http://localhost:11434/api/legal-citation-parse

# Codex CLI parser, used when AI_PROVIDER=codex_cli.
# Requires a working codex CLI login and may be slower than Gemini.
CODEX_CLI_COMMAND=codex

# Fast parse formats - skip AI parsing for these known formats (comma-separated)
# Options: digilegal_scc, law_finder, high_court_order, supreme_court_order, scc_reporter, manupatra, indian_kanoon
FAST_PARSE_FORMATS=digilegal_scc,law_finder,high_court_order,supreme_court_order,scc_reporter,manupatra,indian_kanoon

# Google Docs export
GOOGLE_DRIVE_CREDENTIALS_PATH=./google_credentials.json
GOOGLE_TOKEN_PATH=./google_token.json
GOOGLE_DOC_TITLE=Legal Citation Library
GOOGLE_DOC_ID=
AUTO_EXPORT_GOOGLE_DOCS=false
